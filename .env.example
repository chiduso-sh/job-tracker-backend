# Copy this to .env and fill in your values
# Never commit .env to git

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/job_tracker"

JWT_SECRET="replace-with-a-long-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"

PORT=5000
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# Email — use Gmail App Password or SendGrid
# For Gmail: enable 2FA, then generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="JobTracker <your-email@gmail.com>"
